@dataclass
class BotConfig:
    EMAIL: str = os.getenv("CAPITAL_EMAIL", "")
    PASSWORD: str = os.getenv("CAPITAL_PASSWORD", "")
    API_KEY: str = os.getenv("CAPITAL_API_KEY", "")
    API_PASSWORD: str = os.getenv("CAPITAL_API_PASSWORD", "")
    BASE_URL: str = "https://demo-api-capital.backend-capital.com/api/v1"
    SYMBOLS: List[str] = field(default_factory=lambda: ["BTCUSD", "GOLD", "SILVER"])
    INITIAL_BALANCE: float = 1000.0
    RISK_PERCENT: float = 0.02
    MAX_SIZE: float = 150.0
    MIN_DATA_BARS: int = 50
    COOLDOWN_SECONDS: int = 60
    MAX_POSITIONS: int = 3
    MAX_DRAWDOWN: float = 0.90          # Increased to 25% to avoid unnecessary suspension
    MAX_CONSECUTIVE_LOSSES: int = 5
    MIN_BALANCE: float = 100.0
    MIN_SCORE: int = 4
    MIN_CONFIDENCE: int = 60
    UPDATE_INTERVAL_SEC: int = 60
    POSITION_CHECK_INTERVAL_SEC: int = 10
    STOP_PCT: Dict[str, float] = field(default_factory=lambda: {
        "BTCUSD": 0.015,
        "GOLD": 0.008,
        "SILVER": 0.010,
    })
    TP_MULTIPLIER: float = 2.0
    USE_SMC: bool = True
    USE_SESSION_FILTER: bool = True
    USE_VOLUME_FILTER: bool = True
    USE_MTF: bool = True          # Multi-Timeframe
    USE_OB: bool = True           # Order Blocks
    BACKTEST_MODE: bool = False   # Set to True to run backtest only

